{
    "permissions": {
        "allow": ["Read(/.env.local.example)", "Bash(npm run *)", "Bash(* --version)", "Bash(* --help *)"],
        "deny": ["Read(/.env)", "Read(/.env.*)", "Bash(git push *)", "Bash(git commit *)", "Bash(git * main)"]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-git.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd \"$CLAUDE_PROJECT_DIR\" && npm run fix:prettier 2>/dev/null || true"
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {
        "typescript-lsp@claude-plugins-official": true
    }
}
