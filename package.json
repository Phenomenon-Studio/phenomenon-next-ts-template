{
    "name": "phenomenon-next-ts-template",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack --experimental-https",
        "dev:scan": "APP_MODE=scan next dev --turbopack --experimental-https",
        "build": "next build",
        "build:analyze": "ANALYZE=true next build",
        "start": "next start -p 4173",
        "lint:next": "eslint .",
        "lint:stylelint": "stylelint --cache -q \"**/*.css\"",
        "lint:prettier": "prettier --check \"**/*.{js,ts,tsx,jsx,json,html,css,cjs}\"",
        "lint": "run-s lint:*",
        "fix:prettier": "prettier --write \"**/*.{js,ts,tsx,json,html,css,cjs,mjs}\"",
        "prepare": "husky"
    },
    "browserslist": [
        "> 0.3%",
        "not dead",
        "Firefox >= 113",
        "Chrome >= 111",
        "Edge >= 111",
        "Safari >= 16.4",
        "ios_saf >= 16.4"
    ],
    "dependencies": {
        "@react-hookz/web": "^25.2.0",
        "@t3-oss/env-nextjs": "^0.13.11",
        "@tanstack/react-query": "^5.95.2",
        "clsx": "^2.1.1",
        "cookies-next": "^6.1.1",
        "ky": "^1.14.3",
        "next": "16.2.1",
        "nextjs-toploader": "^3.9.17",
        "nuqs": "^2.8.9",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-error-boundary": "^6.1.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.37.0",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@next/bundle-analyzer": "16.2.1",
        "@svgr/webpack": "^8.1.0",
        "@tanstack/eslint-plugin-query": "^5.95.2",
        "@tanstack/react-query-devtools": "^5.95.2",
        "@types/node": "^24",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "autoprefixer": "^10.4.27",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "husky": "^9.1.7",
        "npm-run-all": "^4.1.5",
        "postcss": "^8",
        "prettier": "^3.8.1",
        "stylelint": "^17.5.0",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "^5"
    },
    "overrides": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3"
    }
}
