{
    "name": "phenomenon-next-ts-template",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack --experimental-https",
        "dev:scan": "APP_MODE=scan next dev --turbopack --experimental-https",
        "build": "next build",
        "build:analyze": "ANALYZE=true next build",
        "start": "next start -p 4173",
        "lint:next": "eslint .",
        "lint:stylelint": "stylelint --cache -q \"**/*.css\"",
        "lint:prettier": "prettier --check \"**/*.{js,ts,tsx,jsx,json,html,css,cjs}\"",
        "lint": "run-s lint:*",
        "fix:prettier": "prettier --write \"**/*.{js,ts,tsx,json,html,css,cjs,mjs}\"",
        "prepare": "husky"
    },
    "browserslist": [
        ">0.3%",
        "not dead",
        "not op_mini all",
        "Firefox >= 93",
        "Chrome >= 94",
        "Edge >= 94",
        "Opera >= 80",
        "Safari >= 15.4",
        "ios_saf >= 15.4",
        "Samsung >= 17"
    ],
    "dependencies": {
        "@react-hookz/web": "^25.1.1",
        "@t3-oss/env-nextjs": "^0.13.8",
        "@tanstack/react-query": "^5.90.3",
        "axios": "^1.12.2",
        "clsx": "^2.1.1",
        "next": "15.5.5",
        "nextjs-toploader": "^3.9.17",
        "nuqs": "^2.7.1",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-error-boundary": "^6.0.0",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "babel-plugin-react-compiler": "^1.0.0",
        "cookies-next": "^6.1.1",
        "@commitlint/cli": "^20.1.0",
        "@commitlint/config-conventional": "^20.0.0",
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.37.0",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
        "@next/bundle-analyzer": "^15.5.5",
        "@svgr/webpack": "^8.1.0",
        "@tanstack/eslint-plugin-query": "^5.91.0",
        "@tanstack/react-query-devtools": "^5.90.2",
        "@types/node": "^24",
        "@types/react": "19.2.2",
        "@types/react-dom": "19.2.2",
        "@typescript-eslint/eslint-plugin": "^8.46.1",
        "@typescript-eslint/parser": "^8.46.1",
        "autoprefixer": "^10.4.21",
        "eslint": "^9",
        "eslint-config-next": "15.5.5",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.0",
        "husky": "^9.1.7",
        "npm-run-all": "^4.1.5",
        "postcss": "^8",
        "prettier": "^3.6.2",
        "stylelint": "^16.25.0",
        "stylelint-config-standard": "^39.0.1",
        "typescript": "^5"
    },
    "overrides": {
        "@types/react": "19.2.2",
        "@types/react-dom": "19.2.2"
    }
}
